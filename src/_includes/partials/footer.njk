<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h3>{{ site.name }}</h3>
      <address>
        {{ site.contact.address_line_1 }}<br>
        {{ site.contact.address_line_2 }}<br>
        <a href="tel:{{ site.contact.phone_e164 }}">{{ site.contact.phone }}</a><br>
        {% for e in site.contact.emails %}
          <a href="mailto:{{ e.address }}">{{ e.address }}</a>{% if not loop.last %}<br>{% endif %}
        {% endfor %}
      </address>
    </div>
    <div>
      <h3>Hours</h3>
      <ul class="hours">
        {% for h in site.hours %}
          <li><span class="day">{{ h.label }}</span><span class="time">{{ h.hours }}</span></li>
        {% endfor %}
      </ul>
      {% for h in site.hours %}{% if h.note %}<p class="hours-note">{{ h.note }}</p>{% endif %}{% endfor %}
    </div>
    <div>
      <h3>Materials we use</h3>
      <ul class="suppliers">
        {% for s in site.suppliers %}
          <li><a href="{{ s.url }}" rel="noopener">{{ s.name }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container copyright">
    &copy; {{ buildtime.year }} {{ site.name }}. All rights reserved.
  </div>
</footer>
